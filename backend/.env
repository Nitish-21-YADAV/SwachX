# ── MongoDB Atlas ──────────────────────────────────────────────────────────
# Single URI — all four databases (authDB, complaintDB, agencyDB, verificationDB)
# will be created automatically under this connection
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@yourcluster.mongodb.net/?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-long-random-secret-string

# ── Cloudinary ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Admin ──────────────────────────────────────────────────────────────────
ADMIN_EMAIL=ADMIN22@gmail.com
ADMIN_PASSWORD=Admin@1234

# ── AI Service ─────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
